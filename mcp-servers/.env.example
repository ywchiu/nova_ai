# ══════════════════════════════════════════════════════════════════════════════
# Nova MCP Servers 環境變數設定
#
# 使用方式：
#   1. 複製本檔為 .env：  cp .env.example .env
#   2. 填入實際的 URL 和 Token
#   3. .env 已在 .gitignore 裡，不會被 commit
#
# 優先順序：環境變數 > .env 檔 > Cline 設定檔
# ══════════════════════════════════════════════════════════════════════════════

# ── Jira ───────────────────────────────────────────────────────────────────
#
# 【Cloud】（xxx.atlassian.net）
#   取得 API Token: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_BASE_URL=https://your-site.atlassian.net
JIRA_EMAIL=your-email@company.com
JIRA_API_TOKEN=
#
# 【Data Center】（公司自建）
#   取得 PAT: Jira → Profile → Personal Access Tokens → Create token
#   如果要用 Data Center，把上面三行註解掉，改用下面兩行：
# JIRA_BASE_URL=http://jira.company.com
# JIRA_PAT=

# ── BitBucket ──────────────────────────────────────────────────────────────
#
# 【Cloud】（bitbucket.org）
#   取得 App Password: https://bitbucket.org/account/settings/app-passwords/
# BB_BASE_URL=https://api.bitbucket.org/2.0
# BB_USER=your-username
# BB_APP_PASSWORD=
#
# 【Data Center】（公司自建）
#   取得 PAT: BitBucket → Profile → Manage Account → HTTP Access Tokens
BB_BASE_URL=http://bitbucket.company.com
BB_PAT=

# ── Jenkins ────────────────────────────────────────────────────────────────
# 取得 API Token: Jenkins → 右上角帳號 → Configure → API Token → Add new Token
JENKINS_URL=http://localhost:9090
JENKINS_USER=admin
JENKINS_API_TOKEN=
