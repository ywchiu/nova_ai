# ══════════════════════════════════════════════════════════════════════════════
# Nova MCP Servers 環境變數設定
#
# 使用方式：
#   1. 複製本檔為 .env：  cp .env.example .env
#   2. 填入實際的 URL 和 Token
#   3. .env 已在 .gitignore 裡，不會被 commit
#
# 優先順序：環境變數 > .env 檔 > Cline 設定檔
# ══════════════════════════════════════════════════════════════════════════════

# ── Jira 9.12.2 (Data Center) ─────────────────────────────────────────────
# 取得 PAT: Jira → 右上角頭像 → Profile → Personal Access Tokens → Create token
JIRA_BASE_URL=http://jira.company.com
JIRA_PAT=

# ── BitBucket 8.19.8 (Data Center) ────────────────────────────────────────
# 取得 PAT: BitBucket → 右上角頭像 → Manage Account → HTTP Access Tokens
BB_BASE_URL=http://bitbucket.company.com
BB_PAT=

# ── Jenkins ────────────────────────────────────────────────────────────────
# 取得 API Token: Jenkins → 右上角帳號 → Configure → API Token → Add new Token
JENKINS_URL=http://jenkins.company.com
JENKINS_USER=your_username
JENKINS_API_TOKEN=
