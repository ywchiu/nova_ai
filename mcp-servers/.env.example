# ── Jira 9.12.2 (Data Center) ─────────────────────────────────────────────
# Get PAT from: Jira → Profile → Personal Access Tokens → Create token
JIRA_BASE_URL=http://jira.company.com
JIRA_PAT=

# ── BitBucket 8.19.8 (Data Center) ────────────────────────────────────────
# Get PAT from: BitBucket → Profile → Manage Account → HTTP Access Tokens
BB_BASE_URL=http://bitbucket.company.com
BB_PAT=

# ── Jenkins ────────────────────────────────────────────────────────────────
# Get API token from: Jenkins → User → Configure → API Token → Add new Token
JENKINS_URL=http://jenkins.company.com
JENKINS_USER=your_username
JENKINS_API_TOKEN=
